# Easy Dataset 生产环境配置示例
# 复制为 .env 后填写真实值：cp .env.example .env

# ========== 必须设置 ==========

# JWT 签名密钥，至少 32 位随机字符串
# 生成方式：openssl rand -hex 32
JWT_SECRET=

# ========== 可选 ==========

# 对外端口，默认 1717
HOST_PORT=1717

# Token 有效期，默认 7d
JWT_EXPIRES_IN=7d

# Prisma 数据库连接（容器内会自动指向 /app/data/db.sqlite，无需修改）
# DATABASE_URL=file:/app/data/db.sqlite
